# =============================================
# TOUCHE VERTE — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter le fichier .env sur GitHub
# =============================================

# --- SERVEUR ---
PORT=5000
NODE_ENV=development

# --- MongoDB Atlas ---
# Créer un compte sur https://cloud.mongodb.com (gratuit)
# Créer un cluster, cliquer "Connect" > "Drivers" > copier l'URL
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/toucheverte?retryWrites=true&w=majority

# --- JWT (authentification admin) ---
# Générer une clé aléatoire longue : https://randomkeygen.com
JWT_SECRET=votre_cle_secrete_tres_longue_ici_minimum_32_caracteres
JWT_EXPIRE=7d

# --- Cloudinary (upload photos) ---
# Créer un compte sur https://cloudinary.com (gratuit)
# Dashboard > API Keys
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# --- Resend (envoi emails) ---
# Créer un compte sur https://resend.com (gratuit, 3000 emails/mois)
# API Keys > Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- Email de destination ---
# L'email qui reçoit les messages du formulaire de contact
EMAIL_TO=contact@toucheverte.co.ma
EMAIL_FROM=noreply@toucheverte.co.ma

# --- URL Frontend (pour CORS) ---
# En dev : http://localhost:3000 ou file://
# En prod : https://toucheverte.vercel.app
FRONTEND_URL=http://localhost:3000
